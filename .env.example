# Smart Search local configuration
# Copy this file to .env and edit values there.

# OCR speed/quality:
# fast = one raw OCR pass only.
# balanced = raw OCR first, enhanced passes only when raw OCR is weak.
# accurate = raw + enhanced + threshold OCR passes.
# Default is fast because handwritten notes did not improve enough from
# repeated OCR passes to justify the CPU cost.
SMART_SEARCH_OCR_MODE=fast

# In balanced mode, skip enhanced OCR when raw OCR meets both thresholds.
SMART_SEARCH_OCR_ADAPTIVE_MIN_CONFIDENCE=80
SMART_SEARCH_OCR_ADAPTIVE_MIN_CHARS=100

# PDF page render scale for OCR. 1 means original PDF page resolution.
# Higher values can be tested for experiments, but cost more CPU.
SMART_SEARCH_PDF_RENDER_SCALE=1

# Number of PDF pages indexed immediately before the rest go to background queue.
SMART_SEARCH_INITIAL_PDF_SYNC_PAGES=3

# 0 means no hard page limit during full PDF OCR.
SMART_SEARCH_PDF_OCR_PAGE_LIMIT=0

# 0 means OCR every embedded image found in Office files.
SMART_SEARCH_OFFICE_IMAGE_OCR_LIMIT=0

# Skip OCR/extraction when a file hash is already indexed.
SMART_SEARCH_SKIP_DUPLICATE_EXTRACTION=true

# Normally false: only start the background OCR queue when new jobs were queued.
SMART_SEARCH_START_QUEUE_WHEN_NO_JOBS=false

# Optional database overrides. Leave blank to use electron/data/documents.sqlite
# and electron/data/documents.json.
# SMART_SEARCH_DB_PATH=
# SMART_SEARCH_SQLITE_DB_PATH=
# SMART_SEARCH_JSON_DB_PATH=

# Optional: load env variables from another file.
# SMART_SEARCH_ENV_PATH=
